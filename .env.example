# ═══════════════════════════════════════════════════════════
# SAFAR PLATFORM — Environment Variables
# Copy this to .env.local and fill in your Supabase values
# ═══════════════════════════════════════════════════════════

# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Service role key — NEVER expose this to the client
# Used only in server-side admin API routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin password for the dashboard (change this!)
ADMIN_PASSWORD=admin123

# App URL (for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
